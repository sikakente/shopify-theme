{% comment %}
  Jersey Gallery Section
  Apple-style full-bleed scroll-reveal product images
{% endcomment %}

{%- style -%}
  .jersey-gallery {
    background: #000;
    color: #fff;
    padding-bottom: 20vh; /* Space to finish scroll */
  }
  
  .jersey-gallery__wrapper {
    position: relative;
    max-width: 100%;
    margin: 0 auto;
  }
  
  .jersey-gallery__slide {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    will-change: transform;
    background: #000; /* SOLID BACKGROUND - Prevents bleed-through */
    box-shadow: 0 -30px 60px rgba(0,0,0,0.8); /* Stronger shadow for separation */
  }

  /* Stack effect: Each slide needs a higher z-index */
  .jersey-gallery__slide:nth-child(1) { z-index: 1; }
  .jersey-gallery__slide:nth-child(2) { z-index: 2; }
  .jersey-gallery__slide:nth-child(3) { z-index: 3; }
  .jersey-gallery__slide:nth-child(4) { z-index: 4; }
  .jersey-gallery__slide:nth-child(5) { z-index: 5; }
  .jersey-gallery__slide:nth-child(6) { z-index: 6; }
  
  .jersey-gallery__image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: #000; /* Fallback background */
  }
  
  .jersey-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Show full image on desktop */
    object-position: center center;
    opacity: 0.95;
    transform: scale(1.05);
    transition: transform 0.5s ease-out, opacity 0.5s ease;
  }
  
  .jersey-gallery__overlay {
    position: absolute;
    inset: 0;
    /* Gradient only at bottom for text readability */
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 50%,
      rgba(0,0,0,0.3) 70%,
      rgba(0,0,0,0.7) 90%,
      rgba(0,0,0,0.85) 100%
    );
    z-index: 2;
  }
  
  .jersey-gallery__content {
    position: absolute;
    bottom: 60px; /* Anchored to bottom */
    left: 50%;
    transform: translateX(-50%) translateY(30px);
    z-index: 3;
    text-align: center;
    padding: 0 20px;
    max-width: 800px;
    width: 100%;
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
    /* No backdrop - rely on gradient + text shadow */
  }

  /* Reveal content when slide becomes active/sticky */
  .jersey-gallery__slide.is-active .jersey-gallery__content {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .jersey-gallery__slide.is-active .jersey-gallery__image {
    transform: scale(1);
    opacity: 1;
  }
  
  .jersey-gallery__title {
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0,0,0,0.8), 0 4px 40px rgba(0,0,0,0.5);
  }
  
  .jersey-gallery__subtitle {
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    font-weight: 400;
    color: rgba(255,255,255,0.95);
    letter-spacing: 0.02em;
    margin: 0;
    text-shadow: 0 2px 10px rgba(0,0,0,0.8), 0 4px 20px rgba(0,0,0,0.5);
  }
  
  /* Placeholder styling */
  .jersey-gallery__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #111;
    z-index: 1;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  
  .jersey-gallery__placeholder-text {
    font-size: 1rem;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px dashed rgba(255,255,255,0.2);
    padding: 20px 40px;
  }

  /* MOBILE OPTIMIZATION */
  @media (max-width: 768px) {
    .jersey-gallery {
      padding-bottom: 10vh;
    }

    .jersey-gallery__slide {
      height: 70vh; /* Shorter on mobile */
      min-height: 400px;
    }

    .jersey-gallery__title {
      font-size: 2rem;
    }

    .jersey-gallery__subtitle {
      font-size: 0.9rem;
      padding: 0 16px;
    }

    .jersey-gallery__content {
      padding: 0 16px;
    }

    /* Mobile uses cover to fill the shorter viewport */
    .jersey-gallery__image {
      object-fit: cover;
      object-position: center top; /* Favor top of image on mobile */
    }
  }

  /* Very small screens */
  @media (max-width: 480px) {
    .jersey-gallery__slide {
      height: 60vh;
      min-height: 350px;
    }

    .jersey-gallery__title {
      font-size: 1.75rem;
    }

    .jersey-gallery__subtitle {
      font-size: 0.85rem;
    }
  }
{%- endstyle -%}

