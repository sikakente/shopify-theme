<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Native IntersectionObserver for Deck Effect
    // This is smoother than GSAP for simple sticky class toggling
    
    const slides = document.querySelectorAll('[data-deck-slide]');
    
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -20% 0px', // Trigger when 20% into view
      threshold: 0
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-active');
        } else {
          // Only remove if we scroll UP past it
          if (entry.boundingClientRect.top > 0) {
             entry.target.classList.remove('is-active');
          }
        }
      });
    }, observerOptions);
    
    slides.forEach(slide => observer.observe(slide));
    
    // Trigger first slide manually
    if (slides.length > 0) slides[0].classList.add('is-active');
  });
</script>

