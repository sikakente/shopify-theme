{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign body_text = section.settings.body_text
  assign background_image = section.settings.background_image
  assign background_video = section.settings.background_video
  assign product_image = section.settings.product_image
-%}

{%- style -%}
  .story-fabric {
    position: relative;
    z-index: 2; /* Sit on top of hero section */
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #000;
    overflow: hidden;
    padding: 80px 24px;
  }

  .story-fabric__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* Parallax Background */
  .story-fabric__bg-image,
  .story-fabric__bg-video {
    width: 100%;
    height: 120%; /* Taller for parallax movement */
    object-fit: cover;
    opacity: 0.6; /* Increased opacity to show texture */
    position: absolute;
    top: 0;
    left: 0;
    will-change: transform;
    transform: translateY(0);
    transition: transform 0.1s linear; /* Smooth parallax */
  }

  /* Gradient Overlay for Readability */
  .story-fabric::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.3) 100%);
    z-index: 2;
    pointer-events: none;
  }

  .story-fabric__content {
    position: relative;
    z-index: 3;
    max-width: 1200px;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .story-fabric__text {
    color: #fff;
  }

  .story-fabric__heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 24px;
    opacity: 0;
    transform: translateY(40px);
  }

  .story-fabric__subheading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    opacity: 0;
    transform: translateY(40px);
  }

  .story-fabric__body {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    opacity: 0;
    margin: 0;
    max-width: 500px;
    transform: translateY(40px);
  }

  .story-fabric__image-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .story-fabric__product {
    max-width: 100%;
    height: auto;
    filter: drop-shadow(0 40px 80px rgba(0,0,0,0.6));
    opacity: 0;
    transform: scale(0.9);
  }

  /* Animations triggered by JS */
  .story-fabric.is-visible .story-fabric__heading {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .story-fabric.is-visible .story-fabric__subheading {
    opacity: 0.9;
    transform: translateY(0);
    transition: opacity 0.8s ease 0.1s, transform 0.8s ease 0.1s;
  }

  .story-fabric.is-visible .story-fabric__body {
    opacity: 0.7;
    transform: translateY(0);
    transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s;
  }

  .story-fabric.is-visible .story-fabric__product {
    opacity: 1;
    transform: scale(1);
    transition: opacity 1s ease 0.3s, transform 1s ease 0.3s;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .story-fabric__content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .story-fabric__text {
      order: 2;
    }

    .story-fabric__image-container {
      order: 1;
    }

    .story-fabric__body {
      max-width: 100%;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .story-fabric__heading,
    .story-fabric__subheading,
    .story-fabric__body,
    .story-fabric__product {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      opacity: 1 !important;
    }
  }
{%- endstyle -%}

<section 
  class="story-fabric"
  id="story-fabric-{{ section.id }}"
  data-story-section
>
  <div class="story-fabric__bg">
    {%- if background_video != blank -%}
      <video 
        class="story-fabric__bg-video"
        data-parallax-depth="0.15"
        autoplay 
        muted 
        loop 
        playsinline
        {% if background_image != blank %}poster="{{ background_image | image_url: width: 1920 }}"{% endif %}
      >
        {%- for source in background_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    {%- elsif background_image != blank -%}
      <img 
        class="story-fabric__bg-image"
        data-parallax-depth="0.15"
        src="{{ background_image | image_url: width: 1920 }}"
        alt=""
        loading="lazy"
      >
    {%- endif -%}
  </div>

  <div class="story-fabric__content">
    <div class="story-fabric__text">
      {%- if heading != blank -%}
        <h2 class="story-fabric__heading">{{ heading }}</h2>
      {%- endif -%}

      {%- if subheading != blank -%}
        <p class="story-fabric__subheading">{{ subheading }}</p>
      {%- endif -%}

      {%- if body_text != blank -%}
        <p class="story-fabric__body">{{ body_text }}</p>
      {%- endif -%}
    </div>

    <div class="story-fabric__image-container">
      {%- if product_image != blank -%}
        <img 
          class="story-fabric__product"
          src="{{ product_image | image_url: width: 800 }}"
          alt="{{ heading | escape }}"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('#story-fabric-{{ section.id }}');
    const parallaxEl = section ? section.querySelector('[data-parallax-depth]') : null;

    if (!section || !parallaxEl) return;

    let ticking = false;

    function updateParallax() {
      const rect = section.getBoundingClientRect();
      const viewHeight = window.innerHeight;
      
      // Only animate if in view
      if (rect.top <= viewHeight && rect.bottom >= 0) {
        // Disable on mobile for performance
        if (window.innerWidth < 768) {
           parallaxEl.style.transform = 'translateY(0)';
           return;
        }

        const depth = parseFloat(parallaxEl.getAttribute('data-parallax-depth') || '0.15');
        const offset = (rect.top - viewHeight * 0.5) * depth;
        
        parallaxEl.style.transform = `translateY(${offset}px)`;
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }, { passive: true });
    
    // Initial call
    updateParallax();
  })();
</script>

{% schema %}
{
  "name": "Story: Fabric",
  "tag": "section",
  "class": "section-story-fabric",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Cotton Reverse Stockinette Knit."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Breathable. Textured. Built to last."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body Text",
      "default": "Our premium cotton reverse stockinette knit combines traditional craftsmanship with modern comfort. Finished with a ribbed trim, each thread is carefully woven to create a fabric that breathes with you."
    },
    {
      "type": "header",
      "content": "Visuals"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background Video",
      "info": "Cinematic loop of fabric texture (Macro shot)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Fallback Background Image",
      "info": "Used if video is loading or unsupported."
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image",
      "info": "Shirt image with transparent background"
    }
  ],
  "presets": [
    {
      "name": "Story: Fabric"
    }
  ]
}
{% endschema %}
