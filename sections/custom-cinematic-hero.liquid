{{ 'custom-waitlist.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-waitlist.js' | asset_url }}" defer></script>

{%- liquid
  assign video = section.settings.hero_video
  assign poster = section.settings.poster_image
  assign lottie_json = section.settings.lottie_json
  assign logo = section.settings.logo | default: settings.logo
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cta_text = section.settings.cta_text
  assign text_color = section.settings.text_color
  assign enable_mobile = section.settings.enable_mobile
-%}

{%- style -%}
  /* Critical CSS inlined for above-the-fold performance */
  .custom-cinematic-hero {
    --text-color: {{ text_color }};
    position: relative;
    width: 100%;
    /* Let height be determined by children (the spacer) */
    background-color: #000;
    z-index: 1;
  }

  .custom-cinematic-hero__pin-spacer {
    height: 120vh; /* Reduced for tighter transition to next section */
    position: relative;
    background-color: #000;
  }

  /* Black bar to cover any gap at the bottom of hero */
  .custom-cinematic-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    background: #000;
    z-index: 1;
  }

  .custom-cinematic-hero__media-wrapper {
    /* Start relative so page can scroll; GSAP will make it fixed during pinning */
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 1;
    /* Default visibility for JS fallback */
    opacity: 1;
    transition: opacity 0.5s ease;
  }

  /* Video & Poster */
  .custom-cinematic-hero__video,
  .custom-cinematic-hero__poster {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .custom-cinematic-hero__poster {
    /* Show poster if no video is present */
    {% if video == blank %}display: block;{% else %}display: none;{% endif %}
    z-index: 1;
  }

  .custom-cinematic-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.6) 100%);
    z-index: 2;
    pointer-events: none;
  }

  /* Floating Product Blocks */
  .custom-cinematic-hero__floating-products {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .floating-product {
    position: absolute;
    will-change: transform;
  }
  
  .floating-product img {
    width: 100%;
    height: auto;
    display: block;
    /* Drop shadow for depth */
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
  }

  /* Dark overlay for text readability and seamless transition */
  .custom-cinematic-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.8) 85%,
      rgba(0, 0, 0, 1) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  /* Text Content */
  .custom-cinematic-hero__content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 3;
    color: var(--text-color);
    max-width: 800px;
    padding: 0 24px;
    width: 100%;
  }

  .custom-cinematic-hero__logo {
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    max-width: 100px;
    width: auto;
    height: auto;
    z-index: 10;
  }

  /* Initial state: Opacity 1 to avoid blank screen if JS fails or pre-scroll. 
     GSAP will handle the 'from' animation to fade it in if needed. */
  .custom-cinematic-hero__heading {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 12px;
  }

  .custom-cinematic-hero__subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 400;
    line-height: 1.5;
    margin: 0 0 32px;
    opacity: 0.7;
  }

  .custom-cinematic-hero__cta {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: none;
    padding: 0;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    cursor: pointer;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .custom-cinematic-hero__cta:hover {
    opacity: 1;
  }

  .custom-cinematic-hero__cta svg {
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-6px); }
    60% { transform: translateY(-3px); }
  }

  .custom-cinematic-hero__lottie {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 200px;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
  }

  /* Mobile: Show poster/products, hide video */
  @media (max-width: 767px) {
    .custom-cinematic-hero__video {
      display: block;
      height: 100%;
      object-fit: cover;
    }
    .custom-cinematic-hero__poster {
      display: none;
    }
    .custom-cinematic-hero__pin-spacer {
      height: auto;
      min-height: 100vh;
      min-height: 100svh; /* Small viewport height - accounts for mobile browser UI */
    }
    .custom-cinematic-hero__media-wrapper {
      position: relative;
      min-height: 100vh;
      min-height: 100svh;
      height: auto;
      opacity: 1 !important;
      transform: none !important;
      overflow: visible; /* Ensure content can overflow and scroll */
    }
    .custom-cinematic-hero__content {
      position: absolute;
    }
    
    /* Mobile Layout for Floating Products - Hide to show the main video clearly */
    .floating-product {
      display: none !important;
    }
  }

  /* Reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .floating-product,
    .custom-cinematic-hero__content * {
      transform: none !important;
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
    }
  }
{%- endstyle -%}

<section 
  class="custom-cinematic-hero" 
  id="cinematic-hero-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-enable-mobile="{{ enable_mobile }}"
  {% if lottie_json != blank %}
    data-lottie-url="{{ lottie_json }}"
  {% endif %}
>
  <div class="custom-cinematic-hero__pin-spacer">
    <div class="custom-cinematic-hero__media-wrapper">
      {%- if video != blank -%}
        <video 
          class="custom-cinematic-hero__video"
          autoplay 
          muted 
          loop 
          playsinline
          {% if poster != blank %}poster="{{ poster | image_url: width: 1920 }}"{% endif %}
        >
          {%- for source in video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>
      {%- endif -%}

      {%- if poster != blank -%}
        <img 
          class="custom-cinematic-hero__poster"
          src="{{ poster | image_url: width: 1920 }}"
          alt="{{ heading | escape }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}

      <div class="custom-cinematic-hero__overlay"></div>

      <!-- Floating Products Container -->
      <div class="custom-cinematic-hero__floating-products">
        {%- for block in section.blocks -%}
          {%- if block.type == 'floating_product' and block.settings.image != blank -%}
            <div 
              class="floating-product" 
              {{ block.shopify_attributes }}
              data-parallax-speed="{{ block.settings.parallax_speed }}"
              style="
                top: {{ block.settings.top_position }}%;
                left: {{ block.settings.left_position }}%;
                width: {{ block.settings.width }}%;
                z-index: {{ block.settings.z_index }};
              "
            >
              <img 
                src="{{ block.settings.image | image_url: width: 1200 }}" 
                alt="{{ block.settings.image.alt | default: 'Kuama Product' }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if logo != blank -%}
        <img 
          class="custom-cinematic-hero__logo"
          src="{{ logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          width="{{ logo.width }}"
          height="{{ logo.height }}"
          loading="eager"
          style="opacity: 1;"
        >
      {%- endif -%}

      <div class="custom-cinematic-hero__content">

        {%- if heading != blank -%}
          <h1 class="custom-cinematic-hero__heading">{{ heading }}</h1>
        {%- endif -%}

        {%- if subheading != blank -%}
          <p class="custom-cinematic-hero__subheading">{{ subheading }}</p>
        {%- endif -%}

        {%- if cta_text != blank -%}
          <button 
            class="custom-cinematic-hero__cta" 
            type="button"
            aria-label="{{ cta_text }}"
            data-hero-cta
          >
            {{ cta_text }}
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
            </svg>
          </button>
        {%- endif -%}
      </div>

      <div class="custom-cinematic-hero__lottie" aria-hidden="true"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cinematic Hero",
  "tag": "section",
  "class": "section-cinematic-hero",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Video Content"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Hero Video",
      "info": "Upload MP4 video. If left blank, product images will be the focus."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Background Image / Poster",
      "info": "Fallback background if no video is provided."
    },
    {
      "type": "header",
      "content": "Lottie Animation"
    },
    {
      "type": "text",
      "id": "lottie_json",
      "label": "Lottie JSON URL",
      "info": "Paste URL of Lottie JSON file."
    },
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Your brand logo (transparent PNG recommended)"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rep Your Roots Anywhere"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium unisex shirts designed with obsessive attention to fit, fabric, and function."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Scroll Down"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile",
      "label": "Enable animations on mobile",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "floating_product",
      "name": "Floating Product",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image",
          "info": "Use a transparent PNG or WebP for best results."
        },
        {
          "type": "range",
          "id": "parallax_speed",
          "label": "Parallax Speed",
          "min": -50,
          "max": 50,
          "step": 5,
          "default": 20,
          "info": "Higher value moves faster. Negative moves opposite direction."
        },
        {
          "type": "header",
          "content": "Positioning (Desktop)"
        },
        {
          "type": "range",
          "id": "top_position",
          "label": "Top Position %",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "left_position",
          "label": "Left Position %",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "width",
          "label": "Width %",
          "min": 10,
          "max": 80,
          "step": 1,
          "default": 30
        },
        {
          "type": "range",
          "id": "z_index",
          "label": "Layer Order",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 1,
          "info": "Higher numbers sit on top of lower numbers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cinematic Hero",
      "blocks": [
        {
          "type": "floating_product",
          "settings": {
            "top_position": 40,
            "left_position": 20,
            "width": 30,
            "parallax_speed": 30
          }
        },
        {
          "type": "floating_product",
          "settings": {
            "top_position": 60,
            "left_position": 70,
            "width": 25,
            "parallax_speed": -20
          }
        }
      ]
    }
  ]
}
{% endschema %}
